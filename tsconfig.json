{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "build-dist",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["src", "build"],
  "exclude": ["node_modules", "dist"]
}